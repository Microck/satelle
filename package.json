{
  "name": "satelle-repository",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "website"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "check:npm": "node --test npm/test/npm-distribution.test.cjs npm/test/package-managers.test.cjs npm/test/release-followup.test.cjs npm/test/release-infrastructure.test.cjs",
    "docs:build": "npm run build --workspace website",
    "docs:dev": "npm run dev --workspace website",
    "release:check": "node npm/scripts/release.cjs check",
    "release:validate-native-archives": "node npm/scripts/release.cjs validate-native-release-archives",
    "test": "npm run check:npm",
    "test:npm": "npm run check:npm"
  }
}
